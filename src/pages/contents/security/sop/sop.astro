---
import SiteLayout, { type Breadcrumb } from '../../../../layouts/SiteLayout.astro';
import { TWITTER_CARD_SUMMARY } from '../../../../components/BaseHead.astro';
import { BASE_URL } from '../../../../consts';
import { securityBreadcrumbList } from '../security.astro';
import type { index } from '../../../../components/HeaderIndex.astro';
import { Image } from 'astro:assets';
import shienshi_2019 from '../img/shienshi_2019.jpg';
import sec_2018_spring from '../img/sec_2018_spring.jpg';
import sec_2017_spring from '../img/sec_2017_spring.jpg';
import { originPagebc } from '../../network/origin.astro';

export const sopPagebc: Breadcrumb = {
  name: "SOP",
  item: `${BASE_URL}/contents/security/sop/sop`
};
const breadcrumbList: Breadcrumb[] = [...securityBreadcrumbList, sopPagebc];
const indexList: index[] = [
  { id: "#sop", name: "SOP" },
  { id: "#sop_cors", name: "SOAとCORS" },
];
---

<SiteLayout
  title="SOP（Same-Origin Policy）"
  description="SOP（同一生成元ポリシー）の解説ページ。Webセキュリティの基本概念について。"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={breadcrumbList}
  indexList={indexList}
>

  <br/>
  <h3 class="title" id="sop">SOPとは</h3>
  <p>
    同一生成元ポリシー(SOP：Same-Origin Policy)
    工事中...<br>

    同一生成元ポリシー（SOP: Same-Origin Policy）は、Webブラウザで適用される情報の悪用防止策です。<br/>
    <a href={originPagebc.item}>{originPagebc.name}</a>の違いによる制約を設けることで、他サイトからの不正なアクセスを防ぎます。<br/>
    <b>参考サイト</b><br/>
    <a href="https://tools.ietf.org/html/rfc6454" target="_blank">RFC6454</a><br/>
    <a href="http://www.tohoho-web.com/ex/same-origin-policy.html" target="_blank">同一生成元ポリシー(Same-Origin Policy)</a><br/>

    情報処理試験のセキュリティスペシャリスト（現：情報処理安全確保支援士）の<a href="https://www.jitec.ipa.go.jp/1_04hanni_sukiru/mondai_kaitou_2016h28.html#28haru" target="_blank">平成28年秋　午後Ⅱ問2</a>でも出題されています。<br>
    まずWebにおける「オリジン」を理解する必要があります。<br>

    <a href={originPagebc.item}>{originPagebc.name}</a>
  </p>

  <h3 class="title" id="sop_cors">SOAとCORS</h3>
  <p>
    現在のWebブラウザでは、標準で<a href="../SOP/SOP.html">同一生成元ポリシー(SOP：Same-Origin Policy)</a>という情報の悪用の防止策が適用されています。<br>
    （詳しくは<a href="https://tools.ietf.org/html/rfc6454" target="_blank">RFC6454</a>をご覧ください。）
    セキュリティの観点で生まれた考え方なのですが、Webサービスを提供する際、他のWebサービスを利用できないので利便性を損ねるという側面もあります。<br>
    そこで、異なるオリジンのサーバーにある選択されたリソースへのアクセスを許可することができる仕組みとして、オリジン間リソース共有(CORS：Cross-Origin Resource Sharing)が誕生しました。<br>
    facebookの「いいね」を設置できるのもCORSのおかげです。<br>
  </p>
  <h3 class="title">参考</h3>
  <p>
    参考サイト
  </p>
  <ol>
    <li>
      <a href="https://www.w3.org/TR/cors/" target="_blank">Cross-Origin Resource Sharing</a><br>
    </li>
    <li>
      <a href="http://www.tohoho-web.com/ex/cors.html" target="_blank">CORS(Cross-Origin Resource Sharing)</a><br>
    </li>
    <li>
      <a href="http://www.tohoho-web.com/ex/same-origin-policy.html" target="_blank">同一生成元ポリシー(Same-Origin Policy)</a><br>
    </li>
    <li>
      <a href="https://en.wikipedia.org/wiki/Cross-origin_resource_sharing" target="_blank">Cross-origin resource sharing</a><br>
    </li>
  </ol>
  <p>
    参考書
  </p>
  <ol>
    <li>
      <a href="https://amzn.to/4qXnPYX" target="_blank" rel="noopener noreferrer">
        絶対わかる情報処理安全確保支援士 2017年春版<br>
        <Image src={sec_2017_spring} alt="絶対わかる情報処理安全確保支援士 2017年春版" width="200"/>
      </a>
    </li>
    <li>
      <a href="https://amzn.to/4s8DUfh" target="_blank" rel="noopener noreferrer">
        絶対わかる情報処理安全確保支援士 2018年春版<br>
        <Image src={sec_2018_spring} alt="絶対わかる情報処理安全確保支援士 2018年春版" width="200"/>
      </a>
    </li>
    <li>
      <a href="https://amzn.to/4dFtRdp" target="_blank">
        情報処理教科書 情報処理安全確保支援士 2019年版<br/>
        <Image src={shienshi_2019} alt="情報処理教科書 情報処理安全確保支援士 2019年版" width="200"/>
      </a>
    </li>
  </ol>
  </dd>
  </p>
  </dd>
  <br/><br/>
</SiteLayout>
