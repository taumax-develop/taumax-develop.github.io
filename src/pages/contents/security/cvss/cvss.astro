---
import SiteLayout, { type Breadcrumb } from '../../../../layouts/SiteLayout.astro';
import { TWITTER_CARD_SUMMARY } from '../../../../components/BaseHead.astro';
import { BASE_URL } from '../../../../consts';
import { securityBreadcrumbList } from '../security.astro';
import type { index } from '../../../../components/HeaderIndex.astro';

export const cvssPagebc: Breadcrumb = {
  name: "CVSS",
  item: `${BASE_URL}/contents/security/cvss/cvss`
};
const breadcrumbList: Breadcrumb[] = [...securityBreadcrumbList, cvssPagebc];
const indexList: index[] = [
  { id: "#cvss", name: "CVSS" }
];
---

<SiteLayout
  title="CVSS（Common Vulnerability Scoring System）"
  description="CVSS（共通脆弱性評価システム）の解説ページ。脆弱性の深刻度を評価する仕組みについて。"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={breadcrumbList}
  indexList={indexList}
>

  <br/>
  <div id="cvss"></div>
  <h3 class="title">CVSSとは</h3>
  <p>
    共通脆弱性評価システム（CVSS: Common Vulnerability Scoring System）は、IT製品の脆弱性に対するオープンで汎用的な評価手法です。<br/>
    <b>参考</b><br/>
    絶対わかる情報処理安全確保支援士 2017年春版 P235<br/>
    情報セキュリティスペシャリスト2016年版 P142<br/>
  </p>

  <br/><br/>
</SiteLayout>
