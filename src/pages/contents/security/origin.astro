---
import SiteLayout, { type Breadcrumb } from '../../../layouts/SiteLayout.astro';
import { TWITTER_CARD_SUMMARY } from '../../../components/BaseHead.astro';
import { BASE_URL } from '../../../consts';
import { indexPagebcList } from '../../index.astro';
import type { index } from '../../../components/HeaderIndex.astro';

export const originPagebc: Breadcrumb = {
  name: "origin",
  item: `${BASE_URL}/contents/security/origin`
};
const breadcrumbList = [...indexPagebcList, originPagebc];
const indexList: index[] = [
  { id: "#origin", name: "オリジン" }
];
---

<SiteLayout
  title="オリジン"
  description="オリジン(Origin)の解説ページ。スキーム、ホスト、ポート番号の組み合わせについて。"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={breadcrumbList}
  indexList={indexList}
>

  <br/>
  <div id="origin"></div>
  <h3 class="title">オリジン(Origin)とは</h3>
  <p>
    オリジン(Origin)は、スキーム（プロトコル）、ホスト、ポート番号の組み合わせです。<br/>
    下記は全て同じオリジンとみなされます（Same-Origin）。<br/>
    1. http://site-a.example.com/<br/>
    2. http://site-a.example.com:80/<br/>
    3. http://site-a.example.com/example.html<br/>
    ※httpのウェルノウンポートが80なので、上記は全て同じオリジンとみなされる。
  </p>
  <p>
    下記は異なるオリジンとみなされます（Cross-Origin）。<br/>
    1. https://site-a.example.com/      ← スキームが異なる（httpとhttps）<br/>
    2. http://site-b.example.com/       ← ホストが異なる（site-aとsite-b）<br/>
    3. http://site-a.example.com:8080/  ← ポート番号が異なる（ウェルノウンポート80と8080）<br/>
  </p>

  <br/><br/>
</SiteLayout>
