---
import SiteLayout, { type Breadcrumb } from '../../../../../layouts/SiteLayout.astro';
import refactoringImg from '../../img/refactoring.jpg';
import legacyCodeImg from '../../img/legacy_code.jpg';
import { BASE_URL } from '../../../../../consts';
import type { index } from '../../../../../components/HeaderIndex.astro';
import { codesmellBcList } from '../Codesmells.astro';

export const dispensablesBc: Breadcrumb = {
  name: "Dispensables",
  item: `${BASE_URL}/contents/development/codesmell/category/dispensables`
};
export const dispensablesBcList: Breadcrumb[] = [...codesmellBcList, dispensablesBc];
const indexList: index[] = [
  { id: '#pagetop', name: 'ページトップ' },
  { id: '#dispensables', name: 'Dispensables' },
  { id: '#comments', name: 'Comments' },
  { id: '#duplicatecode', name: 'Duplicate Code' },
  { id: '#lazyclass', name: 'Lazy Class' },
  { id: '#dataclass', name: 'Data Class' },
  { id: '#deadcode', name: 'Dead Code' },
  { id: '#speculativegenerality', name: 'Speculative Generality' }
];
---
<SiteLayout
  title="Dispensables"
  description="Code Smell: Dispensablesの分類・参考情報をまとめたページです。"
  twitterCardSize="summary_large_image"
  breadcrumbList={dispensablesBcList}
  indexList={indexList}
>

  <br>
  <h3 class="title" id="dispensables">Dispensables</h3>
  <p><a href="https://sourcemaking.com/refactoring/smells/dispensables" target="_blank" rel="noopener noreferrer">Dispensables</a>
    Dispensablesとは、コードをきれいで効率的で理解しやすくする上で必要のないもののことです。</p>
  <h1 id="comments">Comments</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/comments`>Comments（コメント）</a></p>
  <h1 id="duplicatecode">Duplicate Code</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/duplicate_code`>Duplicate Code（重複コード）</a></p>
  <h1 id="lazyclass">Lazy Class</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/lazy_class`>Lazy Class（怠け者クラス）</a></p>
  <h1 id="dataclass">Data Class</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/data_class`>Data Class（データクラス）</a></p>
  <h1 id="deadcode">Dead Code</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/dead_code`>Dead Code（到達不能コード）</a></p>
  <h1 id="speculativegenerality">Speculative Generality</h1>
  <p><a href=`${BASE_URL}/contents/development/codesmell/category/sub_dispensables/speculative_generality`>Speculative Generality（推測的汎用性）</a></p>
  <br/><br/><br/>
  書籍としてはこの辺りが参考になると思います。<br/>
  <br/>
  リファクタリング第2版<br/>
  <a target="_blank" href="https://amzn.to/4m4SktG" rel="noopener noreferrer"><img src={refactoringImg.src} alt="refactoring" /></a>
    <br/>
    レガシーコード改善ガイド<br/>
  <a target="_blank" href="https://amzn.to/44SixVn" rel="noopener noreferrer"><img src={legacyCodeImg.src} alt="legacy_code" /></a>
</SiteLayout>
