---
import SiteLayout, { type Breadcrumb } from '../../../../layouts/SiteLayout.astro';
import { TWITTER_CARD_SUMMARY } from '../../../../components/BaseHead.astro';
import type { index } from '../../../../components/HeaderIndex.astro';
import { BASE_URL } from '../../../../consts';
import { indexPagebcList } from '../../../index.astro';

export const databaseBc: Breadcrumb = {
  name: "Database",
  item: `${BASE_URL}/contents/development/database/database_index`
};
export const databaseBcList: Breadcrumb[] = [...indexPagebcList, databaseBc];
const indexList: index[] = [];
---
<SiteLayout
  title="Database"
  description="Database関連知識のリンク"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={databaseBcList}
  indexList={indexList}
>

  <br>
  <ul>
    <li><a href=`${BASE_URL}/contents/development/database/event/db_design_night_no6`>DB設計したいNight #6 正規化 [online]</a></li>
  </ul>

  <br><br><br><br><br><br><br>
</SiteLayout>
