---
import SiteLayout, { type Breadcrumb } from '../../../../../../layouts/SiteLayout.astro';
import { BASE_URL, TWITTER_CARD_SUMMARY } from '../../../../../../consts';
import { Image } from 'astro:assets';
import refactoring from '../../../img/refactoring.jpg';
import legacy_code from '../../../img/legacy_code.jpg';
import type { index } from '../../../../../../components/HeaderIndex.astro';
import { smplCondExpressBcList } from '../Simplifying_Conditional_Expressions.astro';

export const replaceNestedCondBc: Breadcrumb = {
  name: "Replace Nested Conditional with Guard Clauses",
  item: `${BASE_URL}/contents/development/refactoring/category/sub_simplcondexp/Replace_Nested_Conditional_with_Guard_Clauses`
};
export const replaceNestedCondBcList: Breadcrumb[] = [...smplCondExpressBcList, replaceNestedCondBc];
const indexList: index[] = [
  { id: '#replacenestedconditionalwithguardclauses', name: 'Replace Nested Conditional with Guard Clauses' }
];
---

<SiteLayout
  title="Replace Nested Conditional with Guard Clauses"
  description="リファクタリング: Replace Nested Conditional with Guard Clauses の解説"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={replaceNestedCondBcList}
  indexList={indexList}
>

  <br>
  <h3 class="title" id="replacenestedconditionalwithguardclauses">Replace Nested Conditional with Guard Clauses</h3>
  <p>ここでは<a href=`${BASE_URL}/contents/development/codesmell/Codesmells`>Code Smell</a>を解消するために参考となるリファクタリング技法や、その他参考になりそうな概念を紹介していこうと思います。</p>
  <p>リファクタリングに関してはこの辺りの書籍が参考になると思います。</p>
  <br/>
  リファクタリング第2版<br/>
  <a target="_blank" href="https://amzn.to/4m4SktG" rel="noopener noreferrer"><Image src={refactoring} alt="refactoring" /></a>
  <br/>
  レガシーコード改善ガイド<br/>
  <a target="_blank" href="https://amzn.to/44SixVn" rel="noopener noreferrer"><Image src={legacy_code} alt="legacy_code" /></a>

  <h1>関連するリファクタリング技法</h1>

  <h1 id="simplifyingconditionalexpressions">Simplifying Conditional Expressions</h1>
  <p><a href="https://sourcemaking.com/refactoring/simplifying-conditional-expressions" target="_blank" rel="noopener noreferrer">Simplifying Conditional Expressions</a></p>

  <h2>Replace Nested Conditional with Guard Clauses</h2>
  <p><a href="https://sourcemaking.com/refactoring/replace-nested-conditional-with-guard-clauses" target="_blank" rel="noopener noreferrer">Replace Nested Conditional with Guard Clauses</a></p>
  <p>※関連するCode Smellがなかったためリンクのみ。</p>
</SiteLayout>
