---
import { SITE_TITLE, BASE_URL } from '../consts';
import { TWITTER_CARD_SUMMARY } from '../components/BaseHead.astro';
import SiteLayout, { type Breadcrumb } from '../layouts/SiteLayout.astro';
import type { index } from '../components/HeaderIndex.astro';

export const indexPagebc: Breadcrumb = {
  name: "トップページ",
  item: `${BASE_URL}`
};
export const indexPagebcList: Breadcrumb[] = [indexPagebc];

const indexList: index[] = [
  { id: "#programming", name: "言語、プログラミング" },
  { id: "#self_development", name: "個人開発" },
  { id: "#requirement", name: "要件定義" },
  { id: "#develop_method", name: "開発手法" },
  { id: "#database", name: "データベース" },
  { id: "#test", name: "テスト" },
  { id: "#network", name: "ネットワーク" },
  { id: "#security", name: "セキュリティ" },
];
---

<SiteLayout
  title={SITE_TITLE}
  description="indexページ"
  twitterCardSize={TWITTER_CARD_SUMMARY}
  breadcrumbList={[]}
  indexList={indexList}
>

